{
    "editor.fontFamily": "'FiraCode Nerd Font', Menlo, Monaco, 'Courier New', monospace",
    "editor.mouseWheelZoom": true,
    "csharp.experimental.debug.hotReload": true,
    "python.createEnvironment.trigger": "off",
    "kotlin.languageServer.debugAttach.enabled": true,
    "kotlin.java.home": "/opt/homebrew/opt/openjdk@17",
    "kotlin.codegen.enabled": true,
    "kotlin.scripts.buildScriptsEnabled": true,
    "kotlin.scripts.enabled": true,
    "dart.flutterSdkPath": "/Users/andreighiurtu/DevTools/flutter",
    "arena.enableTabAutocomplete": false,
    "files.exclude": {
        "**/__pycache__": true
    },
    "terminal.integrated.inheritEnv": false,
    "arduino.useArduinoCli": true,
    "arduino.enableUSBDetection": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "cmake.showOptionsMovedNotification": false,
    "debugpy.debugJustMyCode": false,
    "jupyter.debugJustMyCode": false,
    "redhat.telemetry.enabled": true,
    "bevel.java": "java",
    "bevel.largeLanguageModel": "LOCAL",
    "bevel.codelens": true,
    "python.defaultInterpreterPath": "/Users/andreighiurtu/DevTools/miniforge3",
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "vim.leader": " ",
    "vim.handleKeys": {
        "<C-f>": false,
        "<C-h>": false,
        "<C-j>": false,
        "<C-k>": false,
        "<C-l>": false,
        "<C-d>": true,
        "<C-u>": true
    },
    "vim.normalModeKeyBindings": [
        {
            "before": [
                "J"
            ],
            "after": [
                "m",
                "z",
                "J",
                "`",
                "z"
            ]
        },
        {
            "before": [
                "<C-d>"
            ],
            "after": [
                "<C-d>",
                "z",
                "z"
            ]
        },
        {
            "before": [
                "<C-u>"
            ],
            "after": [
                "<C-u>",
                "z",
                "z"
            ]
        },
        {
            "before": [
                "n"
            ],
            "after": [
                "n",
                "z",
                "z",
                "z",
                "v"
            ]
        },
        {
            "before": [
                "N"
            ],
            "after": [
                "N",
                "z",
                "z",
                "z",
                "v"
            ]
        },
        {
            "before": [
                "<leader>",
                "d"
            ],
            "after": [
                "\"",
                "_",
                "d"
            ]
        },
        {
            "before": [
                "Q"
            ],
            "after": [
                "<nop>"
            ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                "J"
            ],
            "after": [
                ":",
                "m",
                " ",
                "'>+1",
                "<CR>",
                "g",
                "v",
                "=",
                "g",
                "v"
            ]
        },
        {
            "before": [
                "K"
            ],
            "after": [
                ":",
                "m",
                " ",
                "'<-2",
                "<CR>",
                "g",
                "v",
                "=",
                "g",
                "v"
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "after": [
                "\"",
                "_",
                "d",
                "P"
            ]
        },
        {
            "before": [
                "<leader>",
                "d"
            ],
            "after": [
                "\"",
                "_",
                "d"
            ]
        }
    ],
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ]
        },
        {
            "before": [
                "<C-c>"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,
    "editor.wordWrap": "off",
    "files.autoSave": "off",
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "none",
    "editor.cursorBlinking": "solid",
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.iconTheme": "material-icon-theme",
    "editor.fontSize": 14,
    "editor.lineHeight": 1.5,
    // "terminal.integrated.fontFamily": "IosevkaTerm Nerd Font Mono",
    "editor.rulers": [
        80
    ],
    "workbench.editor.showTabs": "multiple"
}